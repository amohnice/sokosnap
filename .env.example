# Database connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/soko-snap?retryWrites=true&w=majority

# Clerk Authentication (Get these from Clerk Dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Cloudinary (Get these from Cloudinary Dashboard)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=my_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=sokosnap_uploads
